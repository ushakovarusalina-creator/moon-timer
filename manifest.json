{
  "manifest_version": 3,
  "name": "The Moon Timer",
  "short_name": "Moon Timer",
  "version": "1.0.0",
  "version_name": "1.0.0",
  "description": "Minimalist focus timer with project tracking. Counts your work time, saves it per project, and keeps running even when the popup is closed.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "The Moon Timer"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "alarms", "notifications"],
  "minimum_chrome_version": "102",
  "author": "Your Name",
  "homepage_url": "",
  "offline_enabled": true
}
